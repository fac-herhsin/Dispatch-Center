<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>公司物件調度追蹤系統</title>
    <style>
        :root {
            --primary: #2c3e50;
            --factory: #e67e22; /* 廠務-橘 */
            --purchase: #3498db; /* 採購-藍 */
            --warehouse: #27ae60; /* 倉管-綠 */
        }
        body { font-family: "Microsoft JhengHei", sans-serif; background: #f8f9fa; padding: 20px; }
        .container { max-width: 1000px; margin: auto; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: var(--primary); border-bottom: 2px solid #eee; padding-bottom: 10px; }
        
        /* 篩選按鈕 */
        .filter-group { margin-bottom: 20px; text-align: center; }
        .filter-btn { padding: 8px 16px; margin: 5px; border: none; border-radius: 20px; cursor: pointer; background: #ddd; transition: 0.3s; }
        .filter-btn.active { background: var(--primary); color: white; }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background: var(--primary); color: white; padding: 12px; }
        td { padding: 12px; border-bottom: 1px solid #eee; text-align: center; }

        /* 狀態標籤樣式 */
        .badge { padding: 4px 10px; border-radius: 12px; font-size: 13px; font-weight: bold; }
        .step-1 { background: #ffeaa7; color: #d35400; } /* 待送加工 */
        .step-2 { background: #fab1a0; color: #c0392b; } /* 加工中 */
        .step-3 { background: #81ecec; color: #0984e3; } /* 可載回 */
        .step-4 { background: #55efc4; color: #00b894; } /* 已入庫 */

        .dept-tag { font-size: 12px; color: #777; display: block; }
    </style>
</head>
<body>

<div class="container">
    <h1>📦 物件調度進度看板</h1>
    
    <div class="filter-group">
        <button class="filter-btn active" onclick="filterTable('all')">顯示全部</button>
        <button class="filter-btn" onclick="filterTable('廠務')">廠務部項目</button>
        <button class="filter-btn" onclick="filterTable('採購')">採購部項目</button>
        <button class="filter-btn" onclick="filterTable('倉管')">倉管部項目</button>
    </div>

    <table id="taskTable">
        <thead>
            <tr>
                <th>物件名稱 / 編號</th>
                <th>當前負責部門</th>
                <th>目前進度</th>
                <th>備註事項</th>
            </tr>
        </thead>
        <tbody>
            <tr data-dept="廠務">
                <td><strong>齒輪箱 A-01</strong><span class="dept-tag">#2024001</span></td>
                <td><b style="color:var(--factory)">廠務部</b></td>
                <td><span class="badge step-1">1. 待送去加工</span></td>
                <td>預計明日早上出貨</td>
            </tr>
            <tr data-dept="採購">
                <td><strong>不鏽鋼面板 B-05</strong><span class="dept-tag">#2024005</span></td>
                <td><b style="color:var(--purchase)">採購部</b></td>
                <td><span class="badge step-2">2. 加工完成 (待驗收)</span></td>
                <td>加工廠：○○精密</td>
            </tr>
            <tr data-dept="採購">
                <td><strong>傳動軸 C-12</strong><span class="dept-tag">#2024012</span></td>
                <td><b style="color:var(--purchase)">採購部</b></td>
                <td><span class="badge step-3">3. 可以載回公司</span></td>
                <td>需聯絡司機阿強</td>
            </tr>
            <tr data-dept="倉管">
                <td><strong>鋁製支架 D-03</strong><span class="dept-tag">#2024003</span></td>
                <td><b style="color:var(--warehouse)">倉管部</b></td>
                <td><span class="badge step-4">4. 已入庫完成</span></td>
                <td>儲位：A-12-3</td>
            </tr>
        </tbody>
    </table>
</div>

<script>
    function filterTable(dept) {
        const rows = document.querySelectorAll('#taskTable tbody tr');
        const buttons = document.querySelectorAll('.filter-btn');
        
        // 切換按鈕樣式
        buttons.forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');

        // 過濾邏輯
        rows.forEach(row => {
            if (dept === 'all' || row.getAttribute('data-dept') === dept) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>

</body>
</html>
