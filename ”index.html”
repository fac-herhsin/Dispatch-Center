<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>企業調度管理系統</title>
    <!-- 引入 Tailwind CSS 用於 UI 樣式 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 Font Awesome 用於圖標 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            background-color: #0f172a;
            color: white;
            transition: background-color 0.3s ease;
            margin: 0;
            padding: 0;
        }
        /* 表單容器陰影與圓角 */
        .form-container {
            background-color: white;
            color: #1e293b;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        /* 動態新增品項的動畫 */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.3s ease-out forwards;
        }
        /* 避免在移動端出現水平滾動 */
        html, body {
            overflow-x: hidden;
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- 頁面 1: 部門選擇頁面 -->
    <div id="selectionPage" class="flex flex-col items-center justify-center min-h-screen px-4">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">企業調度管理系統</h1>
        <p class="text-orange-400 font-medium mb-12 text-center">雲端連線成功，請選擇部門</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-6xl">
            <!-- 管理員卡片 -->
            <div onclick="goToForm('管理員')" class="cursor-pointer bg-slate-800/50 border-2 border-orange-400/50 rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-slate-700 transition transform hover:-translate-y-1">
                <i class="fas fa-user-shield text-4xl text-orange-400 mb-4"></i>
                <span class="text-xl font-bold text-white">管理員</span>
            </div>

            <!-- 採購部卡片 -->
            <div onclick="goToForm('採購')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg transform hover:-translate-y-1">
                <i class="fas fa-shopping-cart text-4xl text-orange-500 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">採購部</span>
            </div>

            <!-- 廠務部卡片 -->
            <div onclick="goToForm('廠務')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg transform hover:-translate-y-1">
                <i class="fas fa-truck text-4xl text-blue-600 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">廠務部</span>
            </div>

            <!-- 倉管部卡片 -->
            <div onclick="goToForm('倉管')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg transform hover:-translate-y-1">
                <i class="fas fa-warehouse text-4xl text-green-600 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">倉管部</span>
            </div>
        </div>
    </div>

    <!-- 頁面 2: 調度表單頁面 (預設隱藏) -->
    <div id="formPage" class="hidden min-h-screen bg-slate-50">
        <!-- 頂部導覽列 -->
        <nav class="bg-[#0f172a] text-white px-6 py-4 flex justify-between items-center sticky top-0 z-10">
            <div class="flex items-center space-x-2">
                <span class="text-xl font-bold tracking-wider">調度系統</span>
                <span id="deptTag" class="bg-orange-500 text-xs px-2 py-0.5 rounded text-white font-bold">部門</span>
            </div>
            <div class="flex items-center space-x-4 md:space-x-6">
                <a href="#" class="hover:text-orange-400 text-sm md:text-base">看板</a>
                <button class="bg-orange-500 hover:bg-orange-600 px-3 py-1.5 rounded-lg text-xs md:text-sm font-bold transition">新增單據</button>
                <a href="javascript:void(0)" onclick="goBack()" class="text-gray-400 hover:text-white text-sm">登出</a>
            </div>
        </nav>

        <!-- 表單主體 -->
        <div class="flex flex-col items-center justify-start py-12 px-4">
            <div class="form-container w-full max-w-lg p-6 md:p-8">
                <h2 class="text-2xl font-bold mb-8 text-slate-800 text-center md:text-left">新增調度任務</h2>
                
                <form id="dispatchForm" class="space-y-6">
                    <!-- 調度類型選擇 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">任務類型</label>
                        <select class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 bg-white appearance-none">
                            <option>加工件 (需載回)</option>
                            <option>一般貨物配送</option>
                            <option>急件處理</option>
                            <option>廠際移庫</option>
                        </select>
                    </div>

                    <!-- 對象名稱輸入 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">對象名稱</label>
                        <input type="text" required placeholder="請輸入廠商或地點名稱" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                    </div>

                    <!-- 品項與數量動態列表 -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">調度品項</label>
                        <div id="itemsList" class="space-y-3">
                            <div class="flex space-x-2">
                                <input type="text" required placeholder="品項名稱" class="flex-grow border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                                <input type="number" required placeholder="量" class="w-24 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 text-center">
                            </div>
                        </div>
                    </div>

                    <!-- 增加品項按鈕 -->
                    <button type="button" onclick="addItem()" class="text-blue-600 hover:text-blue-800 text-sm font-bold flex items-center transition">
                        <i class="fas fa-plus-circle mr-1"></i> 增加品項
                    </button>

                    <!-- 送出按鈕 -->
                    <button type="submit" class="w-full bg-[#111827] text-white py-4 rounded-xl font-bold text-lg hover:bg-slate-800 transition mt-6 shadow-md active:scale-[0.98]">
                        送出並儲存
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- 提示訊息 -->
    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white px-8 py-3 rounded-full opacity-0 transition-all duration-300 pointer-events-none z-50 shadow-2xl">
        <i class="fas fa-check-circle text-green-400 mr-2"></i> 任務儲存成功！
    </div>

    <script>
        /**
         * 切換至表單頁面
         */
        function goToForm(dept) {
            document.getElementById('selectionPage').classList.add('hidden');
            document.getElementById('formPage').classList.remove('hidden');
            document.getElementById('deptTag').innerText = dept;
            document.body.style.backgroundColor = '#f8fafc';
            window.scrollTo(0, 0);
        }

        /**
         * 返回部門選擇頁面
         */
        function goBack() {
            if(confirm('確定要登出並返回選擇頁面嗎？')) {
                document.getElementById('formPage').classList.add('hidden');
                document.getElementById('selectionPage').classList.remove('hidden');
                document.body.style.backgroundColor = '#0f172a';
            }
        }

        /**
         * 動態增加品項輸入框
         */
        function addItem() {
            const container = document.getElementById('itemsList');
            const newRow = document.createElement('div');
            newRow.className = 'flex space-x-2 animate-fade-in';
            newRow.innerHTML = `
                <input type="text" required placeholder="品項名稱" class="flex-grow border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                <input type="number" required placeholder="量" class="w-24 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 text-center">
                <button type="button" onclick="this.parentElement.remove()" class="text-gray-400 hover:text-red-500 px-2 transition">
                    <i class="fas fa-trash-alt"></i>
                </button>
            `;
            container.appendChild(newRow);
        }

        /**
         * 處理表單提交
         */
        document.getElementById('dispatchForm').onsubmit = function(e) {
            e.preventDefault();
            const toast = document.getElementById('toast');
            toast.classList.remove('opacity-0', 'translate-y-10');
            toast.classList.add('opacity-100', '-translate-y-2');
            
            setTimeout(() => {
                toast.classList.remove('opacity-100', '-translate-y-2');
                toast.classList.add('opacity-0', 'translate-y-10');
                this.reset();
                document.getElementById('itemsList').innerHTML = `
                    <div class="flex space-x-2">
                        <input type="text" required placeholder="品項名稱" class="flex-grow border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                        <input type="number" required placeholder="量" class="w-24 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 text-center">
                    </div>
                `;
            }, 2500);
        };
    </script>
</body>
</html>
