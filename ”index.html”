import React, { useState, useEffect } from 'react';
import { 
  Truck, Plus, User, Factory, Calendar, Trash2, 
  ChevronDown, ArrowRight, Warehouse, 
  RefreshCw, BellRing, X, CheckCircle2,
  Printer, Square, CheckSquare, ListChecks,
  Package, Trash, UserPlus, LogOut, Bell,
  Settings, UserCog, UserMinus, Info, Lock,
  ChevronUp, ShieldCheck
} from 'lucide-react';

const systemService = {
  saveToDB: async (data) => {
    return new Promise(resolve => setTimeout(() => resolve({ success: true }), 600));
  },
};

const App = () => {
  const [driversList, setDriversList] = useState(['陳師傅', '王小明', '李大華', '張三', '外車-林先生']);
  const [officeStaff, setOfficeStaff] = useState(['廠務部-小周', '倉管部-老李', '採購部-馬先生', '系統管理員']);
  const [unitOptions] = useState(['件', '組', '公斤', '米', '箱', '自定義...']);
  
  const [currentUser, setCurrentUser] = useState(null); 
  const [isSyncing, setIsSyncing] = useState(false);
  const [internalNotify, setInternalNotify] = useState(null);
  
  const [batches, setBatches] = useState([
    { 
      id: 'b1', 
      date: '2024-02-06',
      vendor: '振興金屬加工',
      creatorDept: '廠務部',
      status: '待外送加工',
      driver: '', 
      items: [{ id: 201, name: '不鏽鋼底座', quantity: 50, unit: '件', note: 'A機台專用' }],
      isRead: false,
      officeIsRead: true,
      purchaseConfirmed: false,
      factoryAssigned: false 
    }
  ]);

  const [showModal, setShowModal] = useState(false);
  const [showDriverSelect, setShowDriverSelect] = useState(false);
  const [currentActionBatchId, setCurrentActionBatchId] = useState(null);
  const [showLoginTaskModal, setShowLoginTaskModal] = useState(false);

  // 新單據暫存狀態
  const [newBatchItems, setNewBatchItems] = useState([
    { id: Date.now(), name: '', quantity: 1, unit: '件', isCustomUnit: false, note: '' }
  ]);

  // 權限判定
  const isOfficeUser = officeStaff.includes(currentUser) || currentUser === '系統管理員';
  const isFactoryDept = currentUser?.includes('廠務部') || currentUser === '系統管理員';
  const isPurchaseDept = currentUser?.includes('採購部') || currentUser === '系統管理員';
  const isWarehouseDept = currentUser?.includes('倉管部') || currentUser === '系統管理員';

  // 修改後的權限：廠務、採購、管理員皆可建立
  const canCreateTicket = isFactoryDept || isPurchaseDept || currentUser === '系統管理員';

  const myNewTasks = batches.filter(b => b.driver === currentUser && !b.isRead);
  const factoryNewTasks = batches.filter(b => (b.status === '待外送加工' || b.status === '待載回公司') && !b.factoryAssigned);
  const purchaseTasks = batches.filter(b => b.status === '加工中' && !b.purchaseConfirmed);
  const warehouseTasks = batches.filter(b => b.status === '待入庫' && !b.officeIsRead);

  useEffect(() => {
    if (currentUser) {
      const hasDriverNotify = !isOfficeUser && myNewTasks.length > 0;
      const hasFactoryNotify = isFactoryDept && factoryNewTasks.length > 0;
      const hasPurchaseNotify = isPurchaseDept && purchaseTasks.length > 0;
      const hasWarehouseNotify = isWarehouseDept && warehouseTasks.length > 0;
      if (hasDriverNotify || hasFactoryNotify || hasPurchaseNotify || hasWarehouseNotify) {
        setShowLoginTaskModal(true);
      }
    }
  }, [currentUser]);

  const handleUpdateBatchStatus = async (id, newStatus, driver = null) => {
    setIsSyncing(true);
    const targetBatch = batches.find(b => b.id === id);
    let updatedBatch = { ...targetBatch };

    if (driver) {
      updatedBatch.driver = driver;
      updatedBatch.factoryAssigned = true;
      updatedBatch.isRead = false;
      triggerNotify("調度完成", `已指派 ${driver} 負責此任務`);
    } else if (newStatus) {
      updatedBatch.status = newStatus;
      if (newStatus === '加工中') updatedBatch.factoryAssigned = true;
      if (newStatus === '待載回公司') {
        updatedBatch.factoryAssigned = false;
        updatedBatch.driver = '';
      }
      if (newStatus === '待入庫') updatedBatch.officeIsRead = false;
      if (newStatus === '已入庫') updatedBatch.officeIsRead = true;
    }

    await systemService.saveToDB(updatedBatch);
    setBatches(prev => prev.map(b => b.id === id ? updatedBatch : b));
    setIsSyncing(false);
    setShowDriverSelect(false);
  };

  const triggerNotify = (title, message) => setInternalNotify({ title, message });

  const addFormItem = () => {
    setNewBatchItems([...newBatchItems, { id: Date.now(), name: '', quantity: 1, unit: '件', isCustomUnit: false, note: '' }]);
  };

  const removeFormItem = (id) => {
    if (newBatchItems.length > 1) {
      setNewBatchItems(newBatchItems.filter(item => item.id !== id));
    }
  };

  const updateFormItem = (id, field, value) => {
    setNewBatchItems(newBatchItems.map(item => {
      if (item.id === id) {
        if (field === 'unit' && value === '自定義...') {
          return { ...item, unit: '', isCustomUnit: true };
        }
        return { ...item, [field]: value };
      }
      return item;
    }));
  };

  // 登入介面
  if (!currentUser) {
    return (
      <div className="min-h-screen bg-slate-950 flex items-center justify-center p-6 text-slate-900">
        <div className="bg-white w-full max-w-md rounded-[2.5rem] p-10 shadow-[0_0_50px_rgba(251,191,36,0.15)] text-center border-t-8 border-amber-400">
            <div className="bg-slate-900 w-24 h-24 rounded-3xl flex items-center justify-center text-amber-400 mx-auto mb-6 shadow-xl rotate-3">
              <Truck size={48} />
            </div>
            <h1 className="text-3xl font-black text-slate-900 tracking-tighter">何鑫 <span className="text-amber-500">/</span> 薪昌</h1>
            <p className="text-slate-400 font-bold mt-1 mb-10 text-sm">調度管理系統 v2.0</p>
          
          <div className="space-y-8 text-left">
            <div>
                <div className="flex items-center gap-2 mb-4 px-2">
                    <div className="h-px flex-1 bg-slate-100"></div>
                    <p className="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">辦公室人員</p>
                    <div className="h-px flex-1 bg-slate-100"></div>
                </div>
              <div className="grid grid-cols-1 gap-2">
                {officeStaff.map(u => (
                  <button key={u} onClick={() => setCurrentUser(u)} className="w-full text-left p-4 rounded-2xl bg-slate-50 hover:bg-amber-400 hover:text-slate-950 border border-slate-100 font-black flex justify-between items-center group transition-all">
                    {u} <ArrowRight size={16} className="text-amber-500 group-hover:text-slate-950 group-hover:translate-x-1" />
                  </button>
                ))}
              </div>
            </div>
            <div>
              <div className="flex items-center gap-2 mb-4 px-2">
                    <div className="h-px flex-1 bg-slate-100"></div>
                    <p className="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">外勤師傅</p>
                    <div className="h-px flex-1 bg-slate-100"></div>
                </div>
              <div className="grid grid-cols-2 gap-2">
                {driversList.map(u => (
                  <button key={u} onClick={() => setCurrentUser(u)} className="w-full text-left p-4 rounded-2xl bg-slate-900 text-white hover:bg-amber-400 hover:text-slate-950 font-black text-sm transition-all text-center">
                    {u}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans text-slate-900">
      
      {/* 登入提示彈窗 */}
      {showLoginTaskModal && (
        <div className="fixed inset-0 bg-slate-950/80 backdrop-blur-md z-[400] flex items-center justify-center p-6">
          <div className="bg-white rounded-[3rem] w-full max-w-lg p-10 shadow-2xl border-b-[12px] border-amber-400">
            <div className="w-20 h-20 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center mb-6 mx-auto">
              <BellRing size={40} className="animate-bounce" />
            </div>
            <h2 className="text-2xl font-black text-center mb-2">您好，{currentUser}！</h2>
            <p className="text-slate-400 font-bold text-center mb-8">目前有調度任務需要您處理：</p>
            <div className="space-y-3 max-h-[30vh] overflow-y-auto mb-8 px-2">
              {isFactoryDept && factoryNewTasks.map(t => (
                <div key={t.id} className="bg-slate-900 text-white p-4 rounded-2xl flex justify-between items-center">
                  <span className="font-black">{t.vendor}</span>
                  <span className="text-[10px] bg-amber-400 text-slate-950 px-3 py-1 rounded-full font-black">待調度</span>
                </div>
              ))}
              {!isOfficeUser && myNewTasks.map(t => (
                <div key={t.id} className="bg-slate-900 text-white p-4 rounded-2xl flex justify-between items-center">
                  <span className="font-black">{t.vendor}</span>
                  <span className="text-[10px] bg-amber-400 text-slate-950 px-3 py-1 rounded-full font-black">新任務</span>
                </div>
              ))}
            </div>
            <button onClick={() => setShowLoginTaskModal(false)} className="w-full bg-slate-950 text-white py-5 rounded-2xl font-black shadow-xl hover:bg-slate-800 transition-all">進入系統處理</button>
          </div>
        </div>
      )}

      {/* 頂部導覽列 */}
      <div className="max-w-6xl mx-auto mb-6 flex justify-between items-center bg-slate-950 p-5 rounded-[2rem] shadow-xl border-b-4 border-amber-400">
        <div className="flex items-center gap-4 text-white">
          <div className="bg-amber-400 p-2.5 rounded-xl text-slate-950 shadow-inner"><User size={20} /></div>
          <div><p className="text-[10px] font-black text-amber-400/60 uppercase leading-none mb-1">USER STATUS</p><p className="font-black text-white">{currentUser}</p></div>
        </div>
        <button onClick={() => setCurrentUser(null)} className="text-white font-black hover:text-amber-400 flex items-center gap-2 bg-slate-900 px-5 py-2.5 rounded-xl transition-all border border-slate-800"><LogOut size={18} /> 登出系統</button>
      </div>

      {/* 標題與建立按鈕 */}
      <header className="max-w-6xl mx-auto mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <h1 className="text-3xl font-black text-slate-900 flex items-center gap-3">
          <div className="p-3 bg-slate-950 rounded-2xl text-amber-400 shadow-lg"><Truck size={32} /></div>調度管理系統
        </h1>
        {canCreateTicket && (
          <button onClick={() => {
            setNewBatchItems([{ id: Date.now(), name: '', quantity: 1, unit: '件', isCustomUnit: false, note: '' }]);
            setShowModal(true);
          }} className="bg-amber-400 text-slate-950 font-black px-10 py-5 rounded-3xl flex items-center gap-3 shadow-[0_10px_20px_rgba(251,191,36,0.3)] border-b-4 border-amber-600 active:translate-y-1 active:border-b-0 transition-all text-lg">
            <Plus size={24} strokeWidth={3} /> 建立新單據
          </button>
        )}
      </header>

      {/* 主單據清單 */}
      <div className="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 pb-40">
        {batches.map(batch => {
          const isAwaitingDriver = (batch.status === '待外送加工' || batch.status === '待載回公司') && !batch.driver;
          const isProcessing = batch.status === '加工中';
          const isAwaitingWarehouse = batch.status === '待入庫';
          
          return (
            <div key={batch.id} className="bg-white rounded-[3rem] shadow-xl border border-slate-200 overflow-hidden relative transition-transform hover:scale-[1.01]">
              {/* 狀態標籤 */}
              <div className={`absolute top-0 right-0 px-8 py-2 rounded-bl-[2rem] font-black text-[11px] uppercase tracking-widest ${isAwaitingDriver ? 'bg-amber-400 text-slate-900' : 'bg-slate-900 text-white'}`}>
                {isAwaitingDriver ? '等待廠務調度' : batch.status}
              </div>

              <div className="p-8">
                <div className="mb-6">
                    <h3 className="text-2xl font-black text-slate-900 mb-1">{batch.vendor}</h3>
                    <div className="flex items-center gap-3">
                        <span className="text-slate-400 text-xs font-bold bg-slate-50 px-3 py-1 rounded-full flex items-center gap-1.5"><Calendar size={12}/> {batch.date}</span>
                        <span className="text-slate-400 text-xs font-bold bg-slate-50 px-3 py-1 rounded-full flex items-center gap-1.5"><ShieldCheck size={12}/> {batch.creatorDept}</span>
                    </div>
                    {batch.driver && (
                        <div className="mt-4 flex items-center gap-2 text-slate-700 font-black text-sm bg-amber-50 border border-amber-100 p-3 rounded-2xl w-fit">
                            <Truck size={16} className="text-amber-500" /> 運送師傅：{batch.driver}
                        </div>
                    )}
                </div>

                <div className="space-y-2 mb-10">
                    <p className="text-[10px] font-black text-slate-300 uppercase tracking-widest ml-1 mb-2">Item Details / 品項明細</p>
                    {batch.items.map(i => (
                    <div key={i.id} className="bg-slate-50 p-5 rounded-3xl border border-slate-100 group hover:border-amber-200 transition-colors">
                        <div className="flex justify-between items-center">
                            <span className="font-black text-lg text-slate-800">{i.name}</span>
                            <span className="bg-slate-900 text-amber-400 px-4 py-1.5 rounded-xl font-black text-sm shadow-sm whitespace-nowrap ml-4">
                                {i.quantity} <span className="text-[10px] text-amber-400/70 ml-1">{i.unit}</span>
                            </span>
                        </div>
                        {i.note && <div className="mt-3 text-[11px] text-slate-500 font-bold bg-white/80 p-3 rounded-2xl border border-slate-100 flex items-start gap-2"><Info size={14} className="text-amber-500 shrink-0 mt-0.5"/> 備註：{i.note}</div>}
                    </div>
                    ))}
                </div>

                {/* 動作按鈕 */}
                <div className="flex flex-col gap-3">
                    {isAwaitingDriver && (
                    <button 
                        disabled={!isFactoryDept}
                        onClick={() => { setCurrentActionBatchId(batch.id); setShowDriverSelect(true); }}
                        className={`w-full py-5 rounded-[2rem] font-black flex items-center justify-center gap-3 transition-all ${isFactoryDept ? 'bg-slate-950 text-amber-400 hover:bg-slate-800 shadow-xl border-b-4 border-black' : 'bg-slate-100 text-slate-300'}`}
                    >
                        {isFactoryDept ? <><UserPlus size={20} /> 指派運送師傅</> : <><Lock size={18} /> 等待廠務部調度</>}
                    </button>
                    )}
                    {batch.driver === currentUser && (batch.status === '待外送加工' || batch.status === '待載回公司') && (
                    <button onClick={() => handleUpdateBatchStatus(batch.id, batch.status === '待外送加工' ? '加工中' : '待入庫')} className="w-full bg-amber-400 text-slate-950 py-5 rounded-[2rem] font-black flex items-center justify-center gap-3 hover:bg-amber-500 shadow-xl border-b-4 border-amber-600 active:translate-y-1 active:border-b-0">
                        <CheckCircle2 size={20} /> 我已完成物料{batch.status === '待外送加工' ? '外送' : '載回'}
                    </button>
                    )}
                    {isProcessing && (
                    <button disabled={!isPurchaseDept} onClick={() => handleUpdateBatchStatus(batch.id, '待載回公司')} className={`w-full py-5 rounded-[2rem] font-black flex items-center justify-center gap-3 ${isPurchaseDept ? 'bg-slate-900 text-white hover:bg-slate-800 shadow-xl border-b-4 border-black' : 'bg-slate-100 text-slate-300'}`}>
                        {isPurchaseDept ? <><CheckCircle2 size={20} /> 採購確認加工完成</> : <><Lock size={18} /> 等待採購部確認</>}
                    </button>
                    )}
                    {isAwaitingWarehouse && (
                    <button disabled={!isWarehouseDept} onClick={() => handleUpdateBatchStatus(batch.id, '已入庫')} className={`w-full py-5 rounded-[2rem] font-black flex items-center justify-center gap-3 ${isWarehouseDept ? 'bg-amber-400 text-slate-950 shadow-xl border-b-4 border-amber-600' : 'bg-slate-100 text-slate-300'}`}>
                        {isWarehouseDept ? <><Warehouse size={20} /> 確認物料入庫</> : <><Lock size={18} /> 等待倉管部確認</>}
                    </button>
                    )}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      {/* 指派師傅彈窗 */}
      {showDriverSelect && (
        <div className="fixed inset-0 bg-slate-950/60 backdrop-blur-sm z-[500] flex items-center justify-center p-4">
          <div className="bg-white rounded-[2.5rem] w-full max-w-xs p-8 shadow-2xl border-t-8 border-slate-950">
            <h3 className="text-xl font-black mb-6 text-center text-slate-900">指派人員</h3>
            <div className="space-y-2">
                {driversList.map(name => (
                    <button key={name} onClick={() => handleUpdateBatchStatus(currentActionBatchId, null, name)} className="w-full text-left p-4 rounded-2xl bg-slate-50 hover:bg-amber-400 hover:text-slate-950 font-black border border-slate-100 transition-all">
                        {name}
                    </button>
                ))}
            </div>
            <button onClick={() => setShowDriverSelect(false)} className="w-full mt-6 py-2 text-slate-400 font-bold hover:text-red-500 transition-colors">取消操作</button>
          </div>
        </div>
      )}

      {/* 建立單據彈窗 */}
      {showModal && (
        <div className="fixed inset-0 bg-slate-950/80 backdrop-blur-xl flex items-center justify-center p-4 z-[450]">
          <div className="bg-white rounded-[3.5rem] w-full max-w-2xl p-10 shadow-2xl max-h-[90vh] overflow-y-auto border-t-[15px] border-amber-400">
            <div className="flex justify-between items-center mb-10">
                <h2 className="text-3xl font-black text-slate-900 tracking-tighter">建立新任務單</h2>
                <button onClick={() => setShowModal(false)} className="p-3 hover:bg-slate-100 rounded-2xl transition-all text-slate-400"><X size={28}/></button>
            </div>
            
            <form onSubmit={(e) => {
              e.preventDefault();
              const batch = { 
                id: 'b' + Date.now(), 
                date: new Date().toISOString().split('T')[0],
                vendor: e.target.vendor.value,
                creatorDept: currentUser,
                status: '待外送加工',
                driver: '', 
                items: newBatchItems.map(item => ({
                    ...item,
                    name: item.name || '未填寫品項',
                    unit: item.unit || '件'
                })),
                isRead: false,
                officeIsRead: true,
                purchaseConfirmed: false,
                factoryAssigned: false
              };
              setBatches([batch, ...batches]);
              setShowModal(false);
              triggerNotify("單據已建立", "請等待廠務部指派運送人員");
            }} className="space-y-10">
              
              <div className="bg-slate-900 p-8 rounded-[2.5rem] shadow-lg">
                <label className="text-xs font-black text-amber-400 uppercase mb-4 block ml-2 tracking-widest">Processing Vendor / 加工廠商</label>
                <input name="vendor" required className="w-full bg-slate-800 text-white p-5 rounded-2xl font-black outline-none border-2 border-slate-700 focus:border-amber-400 shadow-inner transition-all text-lg" placeholder="請輸入目的地廠商名稱" />
              </div>

              <div className="space-y-5">
                <div className="flex justify-between items-center ml-2">
                    <label className="text-xs font-black text-slate-400 uppercase tracking-widest">Item List / 品項清單</label>
                    <button type="button" onClick={addFormItem} className="flex items-center gap-2 text-xs font-black text-slate-950 bg-amber-400 px-5 py-2.5 rounded-2xl hover:bg-amber-500 shadow-md transition-all">
                        <Plus size={16} strokeWidth={3} /> 新增品項
                    </button>
                </div>

                {newBatchItems.map((item, index) => (
                    <div key={item.id} className="relative bg-white p-7 rounded-[2.5rem] border-2 border-slate-100 shadow-sm space-y-5 group hover:border-amber-200 transition-all">
                        <div className="flex justify-between items-center mb-2">
                            <span className="text-[10px] font-black text-white bg-slate-900 px-4 py-1.5 rounded-full uppercase tracking-widest shadow-sm">ITEM #{index + 1}</span>
                            {newBatchItems.length > 1 && (
                                <button type="button" onClick={() => removeFormItem(item.id)} className="bg-red-50 text-red-400 p-2 rounded-xl hover:bg-red-500 hover:text-white transition-all">
                                    <Trash2 size={20} />
                                </button>
                            )}
                        </div>
                        <div className="grid grid-cols-1 md:grid-cols-12 gap-5">
                            <div className="md:col-span-6">
                                <label className="text-[10px] font-black text-slate-400 ml-2 mb-1 block">品項名稱</label>
                                <input 
                                    value={item.name} 
                                    onChange={(e) => updateFormItem(item.id, 'name', e.target.value)}
                                    required 
                                    className="w-full bg-slate-50 p-4 rounded-2xl font-black outline-none border-2 border-transparent focus:border-amber-400 transition-all" 
                                    placeholder="例如：不鏽鋼底座" 
                                />
                            </div>
                            <div className="md:col-span-3">
                                <label className="text-[10px] font-black text-slate-400 ml-2 mb-1 block">數量</label>
                                <input 
                                    type="number" 
                                    value={item.quantity} 
                                    onChange={(e) => updateFormItem(item.id, 'quantity', e.target.value)}
                                    min="1"
                                    className="w-full bg-slate-50 p-4 rounded-2xl font-black outline-none border-2 border-transparent focus:border-amber-400 transition-all" 
                                />
                            </div>
                            <div className="md:col-span-3">
                                <label className="text-[10px] font-black text-slate-400 ml-2 mb-1 block">單位</label>
                                <div className="relative">
                                    {item.isCustomUnit ? (
                                        <div className="flex gap-1">
                                            <input 
                                                autoFocus
                                                value={item.unit}
                                                onChange={(e) => updateFormItem(item.id, 'unit', e.target.value)}
                                                className="w-full bg-amber-50 p-4 rounded-2xl font-black outline-none border-2 border-amber-400 text-sm" 
                                                placeholder="單位" 
                                            />
                                            <button 
                                                type="button"
                                                onClick={() => updateFormItem(item.id, 'isCustomUnit', false)}
                                                className="p-2 text-slate-400 hover:text-red-500"
                                            >
                                                <X size={18} />
                                            </button>
                                        </div>
                                    ) : (
                                        <select 
                                            value={item.unit}
                                            onChange={(e) => updateFormItem(item.id, 'unit', e.target.value)}
                                            className="w-full bg-slate-50 p-4 rounded-2xl font-black outline-none border-2 border-transparent focus:border-amber-400 appearance-none text-sm cursor-pointer"
                                        >
                                            {unitOptions.map(opt => <option key={opt} value={opt}>{opt}</option>)}
                                        </select>
                                    )}
                                    {!item.isCustomUnit && <ChevronDown size={18} className="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" />}
                                </div>
                            </div>
                        </div>
                        <div>
                            <label className="text-[10px] font-black text-slate-400 ml-2 mb-1 block">備註說明 / 設備編號</label>
                            <input 
                                value={item.note} 
                                onChange={(e) => updateFormItem(item.id, 'note', e.target.value)}
                                className="w-full bg-slate-50 p-4 rounded-2xl font-black outline-none border-2 border-transparent focus:border-amber-400 text-sm transition-all" 
                                placeholder="填寫加工要求..." 
                            />
                        </div>
                    </div>
                ))}
              </div>

              <button type="submit" className="w-full bg-slate-950 text-amber-400 py-7 rounded-[2.5rem] font-black text-2xl shadow-2xl hover:bg-slate-800 active:scale-95 transition-all border-b-8 border-black">發布任務單</button>
            </form>
          </div>
        </div>
      )}

      {/* 通知元件 */}
      {internalNotify && (
        <div className="fixed bottom-8 right-8 z-[600] w-80 bg-slate-950 text-white p-6 rounded-[2rem] shadow-2xl border-l-8 border-amber-400 animate-in slide-in-from-right">
          <div className="flex justify-between items-center mb-2"><span className="font-black text-amber-400">{internalNotify.title}</span><X size={18} className="cursor-pointer text-slate-500 hover:text-white" onClick={() => setInternalNotify(null)}/></div>
          <p className="text-sm text-slate-400 font-bold">{internalNotify.message}</p>
        </div>
      )}
    </div>
  );
};

export default App;
