<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>何鑫 / 薪昌 调度管理系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0d1117; } /* 深色背景 */
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">

    <div class="bg-white rounded-3xl shadow-xl w-full max-w-md overflow-hidden" style="border-top: 10px solid #fbbf24;">
        
        <div class="text-center pt-8 pb-4">
            <div class="bg-slate-900 w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <span class="text-4xl text-yellow-500">🚚</span>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">何鑫 / 薪昌</h1>
            <p class="text-slate-400 text-sm tracking-widest mt-1">調度管理系統 v2.0</p>
        </div>

        <div class="px-6 py-4">
            <div class="flex items-center justify-center mb-4">
                <div class="h-px bg-slate-200 flex-grow"></div>
                <span class="px-3 text-xs text-slate-400 font-medium">辦公室人員</span>
                <div class="h-px bg-slate-200 flex-grow"></div>
            </div>

            <div class="space-y-3">
                <a href="#" class="flex justify-between items-center bg-slate-50 border border-slate-100 p-4 rounded-xl hover:bg-slate-100 transition shadow-sm">
                    <span class="font-bold text-slate-700">廠務部-小周</span>
                    <span class="text-slate-400">→</span>
                </a>
                <a href="#" class="flex justify-between items-center bg-slate-50 border border-slate-100 p-4 rounded-xl hover:bg-slate-100 transition shadow-sm">
                    <span class="font-bold text-slate-700">倉管部-老李</span>
                    <span class="text-slate-400">→</span>
                </a>
                <a href="#" class="flex justify-between items-center bg-slate-50 border border-slate-100 p-4 rounded-xl hover:bg-slate-100 transition shadow-sm">
                    <span class="font-bold text-slate-700">採購部-馬先生</span>
                    <span class="text-slate-400">→</span>
                </a>
                <a href="#" class="flex justify-between items-center bg-slate-50 border border-slate-100 p-4 rounded-xl hover:bg-slate-100 transition shadow-sm">
                    <span class="font-bold text-slate-700">系統管理員</span>
                    <span class="text-slate-400">→</span>
                </a>
            </div>
        </div>

        <div class="px-6 py-4 pb-10">
            <div class="flex items-center justify-center mb-4">
                <div class="h-px bg-slate-200 flex-grow"></div>
                <span class="px-3 text-xs text-slate-400 font-medium">外勤師傅</span>
                <div class="h-px bg-slate-200 flex-grow"></div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <button class="bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-slate-800 transition">陳師傅</button>
                <button class="bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-slate-800 transition">王小明</button>
                <button class="bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-slate-800 transition">李大華</button>
                <button class="bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-slate-800 transition">張三</button>
                <button class="bg-slate-900 text-white py-3 rounded-xl font-bold hover:bg-slate-800 transition col-span-1">外車-林先生</button>
            </div>
        </div>

    </div>
</body>
</html>
