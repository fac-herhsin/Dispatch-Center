<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>企業調度管理系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            background-color: #0f172a;
            color: white;
            transition: all 0.3s ease;
        }
        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        .form-container {
            background-color: white;
            color: #1e293b;
            border-radius: 20px;
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- 頁面 1: 部門選擇頁面 -->
    <div id="selectionPage" class="flex flex-col items-center justify-center min-h-screen px-4">
        <h1 class="text-4xl font-bold mb-2">企業調度管理系統</h1>
        <p class="text-orange-400 font-medium mb-12">雲端連線成功，請選擇部門</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full max-w-6xl">
            <!-- 管理員 -->
            <div onclick="goToForm('管理員')" class="cursor-pointer bg-slate-800/50 border-2 border-orange-400/50 rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-slate-700 transition group">
                <i class="fas fa-user-shield text-4xl text-orange-400 mb-4"></i>
                <span class="text-xl font-bold">管理員</span>
            </div>

            <!-- 採購部 -->
            <div onclick="goToForm('採購')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg">
                <i class="fas fa-shopping-cart text-4xl text-orange-500 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">採購部</span>
            </div>

            <!-- 廠務部 -->
            <div onclick="goToForm('廠務')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg">
                <i class="fas fa-truck text-4xl text-blue-600 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">廠務部</span>
            </div>

            <!-- 倉管部 -->
            <div onclick="goToForm('倉管')" class="cursor-pointer bg-white rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-gray-100 transition shadow-lg">
                <i class="fas fa-warehouse text-4xl text-green-600 mb-4"></i>
                <span class="text-xl font-bold text-slate-800">倉管部</span>
            </div>
        </div>
    </div>

    <!-- 頁面 2: 調度表單頁面 (預設隱藏) -->
    <div id="formPage" class="hidden min-h-screen bg-slate-50">
        <!-- 頂部導覽列 -->
        <nav class="bg-[#0f172a] text-white px-6 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <span class="text-xl font-bold tracking-wider">調度系統</span>
                <span id="deptTag" class="bg-orange-500 text-xs px-2 py-0.5 rounded text-white">採購</span>
            </div>
            <div class="flex items-center space-x-6">
                <a href="#" class="hover:text-orange-400">看板</a>
                <button class="bg-orange-500 hover:bg-orange-600 px-4 py-1.5 rounded-lg text-sm font-bold">新增單據</button>
                <a href="#" onclick="goBack()" class="text-gray-400 hover:text-white text-sm">登出</a>
            </div>
        </nav>

        <!-- 表單主體 -->
        <div class="flex flex-col items-center justify-start pt-12 px-4">
            <div class="form-container w-full max-w-lg p-8 shadow-2xl">
                <h2 class="text-2xl font-bold mb-8 text-slate-800">新增調度任務</h2>
                
                <form id="dispatchForm" class="space-y-6">
                    <!-- 調度類型 -->
                    <div>
                        <select class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 bg-white">
                            <option>加工件 (需載回)</option>
                            <option>一般貨物配送</option>
                            <option>急件處理</option>
                        </select>
                    </div>

                    <!-- 對象名稱 -->
                    <div>
                        <input type="text" placeholder="對象名稱" class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                    </div>

                    <!-- 品項列表容器 -->
                    <div id="itemsList" class="space-y-3">
                        <div class="flex space-x-2">
                            <input type="text" placeholder="品項" class="flex-grow border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                            <input type="text" placeholder="量" class="w-20 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 text-center">
                        </div>
                    </div>

                    <!-- 增加品項按鈕 -->
                    <button type="button" onclick="addItem()" class="text-blue-600 hover:text-blue-800 text-sm font-medium flex items-center">
                        <span class="mr-1">+</span> 增加品項
                    </button>

                    <!-- 送出按鈕 -->
                    <button type="submit" class="w-full bg-[#111827] text-white py-4 rounded-xl font-bold text-lg hover:bg-slate-800 transition mt-4 shadow-lg">
                        送出並儲存
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- 訊息提示框 (自定義 Alert) -->
    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white px-8 py-3 rounded-full opacity-0 transition-opacity pointer-events-none">
        儲存成功！
    </div>

    <script>
        // 切換到表單頁面
        function goToForm(dept) {
            document.getElementById('selectionPage').classList.add('hidden');
            document.getElementById('formPage').classList.remove('hidden');
            document.getElementById('deptTag').innerText = dept;
            document.body.style.backgroundColor = '#f8fafc'; // 切換為亮色背景
        }

        // 返回選單
        function goBack() {
            document.getElementById('formPage').classList.add('hidden');
            document.getElementById('selectionPage').classList.remove('hidden');
            document.body.style.backgroundColor = '#0f172a'; // 切換回深色背景
        }

        // 動態增加品項
        function addItem() {
            const container = document.getElementById('itemsList');
            const newRow = document.createElement('div');
            newRow.className = 'flex space-x-2 animate-fade-in';
            newRow.innerHTML = `
                <input type="text" placeholder="品項" class="flex-grow border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400">
                <input type="text" placeholder="量" class="w-20 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-slate-400 text-center">
                <button type="button" onclick="this.parentElement.remove()" class="text-gray-400 hover:text-red-500 px-2">
                    <i class="fas fa-times"></i>
                </button>
            `;
            container.appendChild(newRow);
        }

        // 表單送出處理
        document.getElementById('dispatchForm').onsubmit = function(e) {
            e.preventDefault();
            const toast = document.getElementById('toast');
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            
            setTimeout(() => {
                toast.classList.remove('opacity-100');
                toast.classList.add('opacity-0');
            }, 3000);
        };
    </script>
</body>
</html>
