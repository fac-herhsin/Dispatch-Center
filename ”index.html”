<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>公司內部物件調度系統</title>
    <style>
        body { font-family: sans-serif; background-color: #f4f7f6; margin: 20px; }
        h2 { color: #333; text-align: center; }
        table { width: 100%; border-collapse: collapse; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        th, td { padding: 12px; border: 1px solid #ddd; text-align: center; }
        th { background-color: #007bff; color: white; }
        
        /* 狀態標籤顏色 */
        .status { padding: 5px 10px; border-radius: 4px; font-weight: bold; font-size: 0.9em; }
        .status-wait { background-color: #ffc107; color: black; } /* 待加工 */
        .status-done { background-color: #17a2b8; color: white; } /* 已完成 */
        .status-shipping { background-color: #28a745; color: white; } /* 可載回 */
        .status-stored { background-color: #6c757d; color: white; } /* 已入庫 */
        
        .btn { padding: 6px 12px; cursor: pointer; border: none; border-radius: 4px; background: #007bff; color: white; transition: 0.3s; }
        .btn:hover { background: #0056b3; }
    </style>
</head>
<body>

    <h2>📦 物件加工調度追蹤表</h2>

    <table>
        <thead>
            <tr>
                <th>物件編號</th>
                <th>物件名稱</th>
                <th>負責部門</th>
                <th>目前狀態</th>
                <th>操作面板 (模擬)</th>
            </tr>
        </thead>
        <tbody id="task-list">
            <tr>
                <td>#A001</td>
                <td>不鏽鋼支架</td>
                <td>廠務部</td>
                <td><span class="status status-wait">待送加工</span></td>
                <td><button class="btn" onclick="alert('狀態已更新為：已完成加工')">更新進度</button></td>
            </tr>
            <tr>
                <td>#A002</td>
                <td>精密齒輪</td>
                <td>採購部</td>
                <td><span class="status status-done">加工完成</span></td>
                <td><button class="btn">通知載回</button></td>
            </tr>
            <tr>
                <td>#A003</td>
                <td>鋁合金外殼</td>
                <td>倉管部</td>
                <td><span class="status status-shipping">可載回公司</span></td>
                <td><button class="btn">確認入庫</button></td>
            </tr>
        </tbody>
    </table>

</body>
</html>
