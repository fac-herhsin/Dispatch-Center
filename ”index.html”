<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>企業調度管理系統 - 穩定版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap');
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #f8fafc; }
        .tab-active { border-bottom: 4px solid #0f172a; color: #0f172a; font-weight: 900; }
        .sync-spin { animation: spin 1s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>
</head>
<body class="min-h-screen">

    <!-- 錯誤提示遮罩 (預設隱藏) -->
    <div id="errorOverlay" class="hidden fixed inset-0 bg-red-600/90 z-[200] flex items-center justify-center p-6 text-white text-center">
        <div>
            <i class="fas fa-exclamation-triangle text-6xl mb-4"></i>
            <h2 class="text-2xl font-bold mb-2">Firebase 連線失敗</h2>
            <p id="errorMsg" class="mb-6 opacity-90">請確認您已正確填寫 Firebase 設定資訊。</p>
            <button onclick="location.reload()" class="bg-white text-red-600 px-6 py-2 rounded-full font-bold">重新整理</button>
        </div>
    </div>

    <!-- 登入介面 -->
    <div id="loginOverlay" class="fixed inset-0 bg-slate-900 z-[100] flex items-center justify-center p-4">
        <div class="max-w-5xl w-full text-center">
            <h1 class="text-4xl font-black text-white mb-4 tracking-widest">企業調度管理系統</h1>
            <p id="statusMsg" class="text-amber-500 font-bold mb-12">正在初始化雲端系統...</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <button onclick="login('管理員')" class="bg-slate-800 border border-amber-500/50 p-8 rounded-3xl text-white hover:bg-slate-700 transition-all">
                    <i class="fas fa-user-shield text-3xl mb-4 text-amber-500"></i>
                    <div class="font-bold">管理員</div>
                </button>
                <button onclick="login('採購')" class="bg-white p-8 rounded-3xl text-slate-800 hover:shadow-xl transition-all">
                    <i class="fas fa-shopping-cart text-3xl mb-4 text-amber-600"></i>
                    <div class="font-bold">採購部</div>
                </button>
                <button onclick="login('廠務')" class="bg-white p-8 rounded-3xl text-slate-800 hover:shadow-xl transition-all">
                    <i class="fas fa-truck text-3xl mb-4 text-blue-600"></i>
                    <div class="font-bold">廠務部</div>
                </button>
                <button onclick="login('倉管')" class="bg-white p-8 rounded-3xl text-slate-800 hover:shadow-xl transition-all">
                    <i class="fas fa-warehouse text-3xl mb-4 text-emerald-600"></i>
                    <div class="font-bold">倉管部</div>
                </button>
            </div>
        </div>
    </div>

    <!-- 主程式內容 -->
    <div id="mainApp" class="hidden">
        <nav class="bg-slate-900 text-white p-4 flex justify-between items-center sticky top-0 z-50">
            <div class="font-black text-xl">調度系統 <span id="userBadge" class="text-xs bg-amber-500 text-black px-2 py-0.5 rounded ml-2"></span></div>
            <div class="flex gap-4 items-center">
                <button onclick="showPanel('board')" class="text-sm font-bold">看板</button>
                <button id="navCreate" onclick="showPanel('create')" class="hidden text-sm font-bold bg-amber-500 text-black px-3 py-1 rounded">新增單據</button>
                <button onclick="location.reload()" class="text-xs opacity-50">登出</button>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto p-4">
            <!-- 看板標籤 -->
            <div id="boardPanel">
                <div class="flex gap-2 overflow-x-auto mb-6 border-b border-slate-200">
                    <button onclick="setTab(0)" id="tab-0" class="px-4 py-3 text-sm whitespace-nowrap">待出貨</button>
                    <button onclick="setTab(1)" id="tab-1" class="px-4 py-3 text-sm whitespace-nowrap">進行中</button>
                    <button onclick="setTab(2)" id="tab-2" class="px-4 py-3 text-sm whitespace-nowrap">待回廠</button>
                    <button onclick="setTab(3)" id="tab-3" class="px-4 py-3 text-sm whitespace-nowrap font-bold text-emerald-600">待入庫</button>
                    <button onclick="setTab(4)" id="tab-4" class="px-4 py-3 text-sm whitespace-nowrap">已結案</button>
                </div>
                <div id="taskBoard" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
            </div>

            <!-- 新增單據 -->
            <div id="createPanel" class="hidden max-w-lg mx-auto bg-white p-6 rounded-3xl shadow-lg">
                <h2 class="text-xl font-bold mb-4">新增調度任務</h2>
                <div class="space-y-4">
                    <select id="taskType" class="w-full p-3 border rounded-xl">
                        <option value="加工件">加工件 (需載回)</option>
                        <option value="銷售">銷售 (不需載回)</option>
                    </select>
                    <input type="text" id="targetName" placeholder="對象名稱" class="w-full p-3 border rounded-xl">
                    <div id="itemListInput" class="space-y-2">
                        <div class="flex gap-2">
                            <input type="text" class="item-name flex-1 p-2 border rounded-lg" placeholder="品項">
                            <input type="number" class="item-qty w-20 p-2 border rounded-lg" placeholder="量">
                        </div>
                    </div>
                    <button onclick="addInputRow()" class="text-sm text-blue-600">+ 增加品項</button>
                    <button onclick="createNewTask()" class="w-full bg-slate-900 text-white p-4 rounded-xl font-bold">送出並儲存</button>
                </div>
            </div>
        </main>
    </div>

    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-black text-white px-6 py-2 rounded-full opacity-0 transition-all"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, collection, onSnapshot, updateDoc, query, orderBy } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // --- Firebase 配置區 ---
        let config;
        try {
            // 如果是在我的環境中執行，會自動抓取金鑰
            config = JSON.parse(__firebase_config);
        } catch (e) {
            // 如果是在 GitHub，請在此替換為你自己的 Firebase Config
            config = {
                apiKey: "填入你的API_KEY",
                authDomain: "你的專案.firebaseapp.com",
                projectId: "你的專案ID",
                storageBucket: "你的專案.appspot.com",
                messagingSenderId: "你的傳送者ID",
                appId: "你的APP_ID"
            };
        }

        let db, auth;
        try {
            const app = initializeApp(config);
            db = getFirestore(app);
            auth = getAuth(app);
        } catch (err) {
            document.getElementById('errorOverlay').classList.remove('hidden');
            document.getElementById('errorMsg').innerText = err.message;
        }

        let currentUserDept = null;
        let activeTab = 0;
        let tasks = [];
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'my-task-app';

        // 監聽登入狀態
        onAuthStateChanged(auth, (user) => {
            if (user) {
                document.getElementById('statusMsg').innerText = "雲端連線成功，請選擇部門";
            } else {
                signInAnonymously(auth).catch(e => {
                    document.getElementById('errorOverlay').classList.remove('hidden');
                    document.getElementById('errorMsg').innerText = "無法進行匿名登入，請檢查 Firebase 權限設定。";
                });
            }
        });

        window.login = (dept) => {
            currentUserDept = dept;
            document.getElementById('loginOverlay').classList.add('hidden');
            document.getElementById('mainApp').classList.remove('hidden');
            document.getElementById('userBadge').innerText = dept;
            if(dept === '管理員' || dept === '採購') document.getElementById('navCreate').classList.remove('hidden');
            
            // 開始監聽資料 (使用公共路徑)
            const q = collection(db, 'artifacts', appId, 'public', 'data', 'tasks');
            onSnapshot(q, (snapshot) => {
                tasks = snapshot.docs.map(doc => ({...doc.data(), docId: doc.id}));
                tasks.sort((a,b) => b.id - a.id);
                render();
            }, (err) => {
                alert("Firestore 讀取失敗: " + err.message);
            });
        };

        window.showPanel = (id) => {
            document.getElementById('boardPanel').classList.toggle('hidden', id !== 'board');
            document.getElementById('createPanel').classList.toggle('hidden', id !== 'create');
        };

        window.setTab = (idx) => {
            activeTab = idx;
            for(let i=0; i<5; i++) {
                document.getElementById(`tab-${i}`).classList.toggle('tab-active', i === idx);
            }
            render();
        };

        window.addInputRow = () => {
            const div = document.createElement('div');
            div.className = 'flex gap-2';
            div.innerHTML = `<input type="text" class="item-name flex-1 p-2 border rounded-lg" placeholder="品項"><input type="number" class="item-qty w-20 p-2 border rounded-lg" placeholder="量">`;
            document.getElementById('itemListInput').appendChild(div);
        };

        window.createNewTask = async () => {
            const target = document.getElementById('targetName').value;
            if(!target) return alert("請輸入對象名稱");
            const items = Array.from(document.querySelectorAll('#itemListInput > div')).map(row => ({
                name: row.querySelector('.item-name').value,
                qty: row.querySelector('.item-qty').value
            })).filter(i => i.name);

            const id = Date.now();
            const data = {
                id,
                target,
                items,
                type: document.getElementById('taskType').value,
                stage: 0,
                createdAt: new Date().toLocaleString()
            };

            await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', String(id)), data);
            showPanel('board');
            showToast("已建立任務");
        };

        function checkDuty(task) {
            if (currentUserDept === '管理員') return true;
            if (task.stage === 0 && currentUserDept === '廠務') return true;
            if (task.stage === 1) return (task.type === '加工件' ? currentUserDept === '採購' : currentUserDept === '廠務');
            if (task.stage === 2 && currentUserDept === '廠務') return true;
            if (task.stage === 3 && currentUserDept === '倉管') return true;
            return false;
        }

        window.nextStep = async (id) => {
            const task = tasks.find(t => t.id === id);
            if(!checkDuty(task)) return;
            let next = task.stage + 1;
            if(task.type === '銷售' && task.stage === 1) next = 3; // 銷售直接跳待入庫
            await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', String(id)), { stage: next });
        };

        window.render = () => {
            const board = document.getElementById('taskBoard');
            board.innerHTML = '';
            const filtered = tasks.filter(t => t.stage === activeTab);
            
            filtered.forEach(t => {
                const canAct = checkDuty(t) && t.stage < 4;
                const card = document.createElement('div');
                card.className = "bg-white p-5 rounded-2xl shadow-sm border";
                card.innerHTML = `
                    <div class="text-xs text-slate-400 mb-2">單號: ${t.id} | ${t.type}</div>
                    <div class="text-lg font-bold mb-3">${t.target}</div>
                    <div class="space-y-1 mb-4">
                        ${t.items.map(i => `<div class="flex justify-between text-sm"><span>${i.name}</span><b>${i.qty}</b></div>`).join('')}
                    </div>
                    ${t.stage < 4 ? `
                        <button onclick="nextStep(${t.id})" class="w-full py-2 rounded-lg font-bold ${canAct ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-300'}" ${!canAct ? 'disabled' : ''}>
                            ${canAct ? '執行下一階段' : '等待處理'}
                        </button>
                    ` : '<div class="text-center text-emerald-600 font-bold">已入庫完成</div>'}
                `;
                board.appendChild(card);
            });
        };

        function showToast(m) {
            const t = document.getElementById('toast');
            t.innerText = m; t.style.opacity = 1;
            setTimeout(() => t.style.opacity = 0, 2000);
        }
    </script>
</body>
</html>
